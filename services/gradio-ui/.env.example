# n8n webhook endpoints
# Use webhook-test/ while the workflow is open in the n8n UI (test mode)
# Use webhook/ once the workflow is published (production)
N8N_WEBHOOK_URL=http://localhost:5678/webhook-test/property-intake
N8N_STATUS_URL=http://localhost:5678/webhook-test

# Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Gradio server
GRADIO_SERVER_PORT=7860
GRADIO_SERVER_NAME=0.0.0.0

# ── Docker overrides (host.docker.internal) ────────────────────────────────────
# Uncomment when running the UI inside Docker on macOS / Windows:
# N8N_WEBHOOK_URL=http://host.docker.internal:5678/webhook-test/property-intake
# N8N_STATUS_URL=http://host.docker.internal:5678/webhook-test
# OLLAMA_URL=http://host.docker.internal:11434
